# =============================================================================
# Environment Variables — Quản lý Thành tích Giáo viên
# Copy file này thành .env.local và điền giá trị thật
# KHÔNG commit .env.local vào git
# =============================================================================

# Database (Supabase PostgreSQL)
# DATABASE_URL  → pgBouncer connection pooling (dùng cho runtime queries)
# DIRECT_URL    → Direct connection (dùng cho prisma migrate / prisma db push)
# Xem ADR-002 và ADR-004 trong docs/technical/DECISIONS.md
DATABASE_URL="postgresql://postgres:[password]@db.[project-ref].supabase.co:6543/postgres?pgbouncer=true"
DIRECT_URL="postgresql://postgres:[password]@db.[project-ref].supabase.co:5432/postgres"

# NextAuth.js (ADR-003)
# NEXTAUTH_SECRET: generate bằng `openssl rand -base64 32`
NEXTAUTH_SECRET="your-secret-here"
NEXTAUTH_URL="http://localhost:3000"

# Cloudinary (optional — dùng cho upload file SKKN, chứng nhận)
CLOUDINARY_CLOUD_NAME=""
CLOUDINARY_API_KEY=""
CLOUDINARY_API_SECRET=""
