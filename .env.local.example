# Local development with Docker PostgreSQL
# Copy this to .env.local and fill in values

# Docker PostgreSQL (both URLs same for local — no pgBouncer)
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/qlthanh_tich"
DIRECT_URL="postgresql://postgres:postgres@localhost:5432/qlthanh_tich"

# NextAuth (generate with: openssl rand -base64 32)
NEXTAUTH_SECRET="dev-secret-change-in-production"
NEXTAUTH_URL="http://localhost:3000"

# Cloudinary (optional for local dev)
CLOUDINARY_CLOUD_NAME=""
CLOUDINARY_API_KEY=""
CLOUDINARY_API_SECRET=""
